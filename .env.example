# Настройки БД
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=plugins
DB_PASSWORD=your_secure_password
DB_NAME=minecraft_db

# Секретный ключ для JWT (сгенерируй случайную строку, например openssl rand -hex 32)
SECRET_KEY=super_secret_key_change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Настройки Telegram
TG_BOT_TOKEN=123456789:AAF...
TG_PROXY=socks5://ip:port

# Список разрешенных доменов
CORS_ORIGINS=http://localhost

# Токен бота (для сайта)
SITE_BOT_TOKEN=123456789:AAHd.......
# Имя бота без @ (для генерации ссылки)
SITE_BOT_NAME=BelugaSiteBot

SWAGGER_USER=admin
SWAGGER_PASSWORD=super_secure_password_123

PLACEHOLDER_API_HOST=127.0.0.1
PLACEHOLDER_API_PORT=8080

MAIL_USERNAME=noreply@твои-домен.com
MAIL_PASSWORD=твой_пароль_приложения_zoho
MAIL_FROM=noreply@твои-домен.com
MAIL_PORT=465
MAIL_SERVER=smtp.zoho.com
MAIL_STARTTLS=False
MAIL_SSL_TLS=True
USE_CREDENTIALS=True
VALIDATE_CERTS=True

NICKPERM=default